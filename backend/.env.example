# Base de donnees PostgreSQL (Neon.tech)
DATABASE_URL=

# Cloudinary (fichiers <= 10 Mo)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# JWT
JWT_SECRET=

# Cloudflare R2 (fichiers > 10 Mo, production — gratuit 10 Go)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=mon-archive
R2_PUBLIC_URL= # facultatif, si domaine Cloudflare personnalisé

# Frontend URL (CORS)
FRONTEND_URL=https://mon-archive.vercel.app
